rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // For a real DB, role checks would read from the users database.
    // If user's document says role == 'admin' they have total privileges.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isArtist() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "artist" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.role == "regular"; // Can't escalate roles
      allow update: if isAdmin(); // Only admin can upgrade user roles or adjust levels
      allow delete: if isAdmin();
    }

    // --- Artists Collection ---
    match /artists/{artistId} {
      allow read: if true; // Public bios
      allow write: if isAdmin() || (isArtist() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.artistId == artistId);
    }

    // --- Releases Collection ---
    match /releases/{releaseId} {
      allow read: if true; // Public catalog
      allow create: if isArtist() && request.resource.data.artistId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.artistId;
      allow update: if isArtist() && resource.data.artistId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.artistId;
      allow delete: if isAdmin();
    }

    // --- Merch Collection ---
    match /merch/{itemId} {
      allow read: if true; // Public store
      allow write: if isAdmin(); // Only admin manages catalog & pricing
    }

    // --- Blog Collection ---
    match /blog/{entryId} {
      allow read: if true; // Public news
      allow write: if isAdmin(); // Only admins/label represent write blog entries
    }

    // --- Bookings Collection ---
    match /bookings/{bookingId} {
      // Inquiries are private to requester, specific artist, and admin
      allow read: if isAdmin() || 
        (isSignedIn() && (
          resource.data.requesterEmail == request.auth.token.email ||
          resource.data.artistId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.artistId
        ));
      allow create: if true; // Anyone can submit a booking request
      allow update: if isAdmin() || (isArtist() && resource.data.artistId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.artistId);
      allow delete: if isAdmin();
    }

    // --- Cells Collection ---
    match /cells/{cellId} {
      allow read: if true; // Public homepage elements
      allow write: if isAdmin(); // Managed of the record label
    }

    // --- Stream Chat Collection ---
    match /stream/{messageId} {
      allow read: if true; // Public stream chat to watch
      allow create: if true; // Allowed to interact in preview sandbox environment
      allow delete: if true; // Moderation
    }

    // --- Navigation Collection ---
    match /navigation/{configId} {
      allow read: if true;
      allow write: if true; // Allowed so both local and remote users can configure navigation
    }

    // --- Live Sessions Collection ---
    match /liveSessions/{sessionId} {
      allow read: if true;
      allow write: if true; // Allowed so DJs and admins can create and update sessions

      match /viewers/{userId} {
        allow read: if true;
        allow write: if true;
      }
      match /connections/{userId} {
        allow read: if true;
        allow write: if true;
        
        match /{doc=**} {
           allow read: if true;
           allow write: if true;
        }
      }
    }
  }
}
